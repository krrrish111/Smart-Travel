<?xml version="1.0" encoding="UTF-8"?>
<Context>
    <!-- Use standard JarScanFilter to explicitly skip TLD and Pluggability scanning for unnecessary libraries -->
    <JarScanner>
        <JarScanFilter defaultTldScan="false" defaultPluggabilityScan="false"
                       tldScan="jstl-*.jar,standard-*.jar,jakarta.servlet.jsp.jstl-*.jar,taglibs-standard-*.jar"
                       pluggabilityScan="none"/>
    </JarScanner>
</Context>

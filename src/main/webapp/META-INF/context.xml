        <JarScanFilter defaultTldScan="true" defaultPluggabilityScan="true"
                       tldSkip="twilio-*.jar,jackson-*.jar,itextpdf-*.jar,mysql-*.jar,gson-*.jar,jbcrypt-*.jar,HikariCP-*.jar,mail-*.jar,jakarta.mail-*.jar,slf4j-*.jar,guava-*.jar,httpclient-*.jar,httpcore-*.jar,commons-*.jar,jjwt-*.jar,jakarta.activation-*.jar"
                       pluggabilitySkip="twilio-*.jar,jackson-*.jar,itextpdf-*.jar,mysql-*.jar,gson-*.jar,jbcrypt-*.jar,HikariCP-*.jar,mail-*.jar,jakarta.mail-*.jar,slf4j-*.jar,guava-*.jar,httpclient-*.jar,httpcore-*.jar,commons-*.jar,jjwt-*.jar,jakarta.activation-*.jar"/>
    </JarScanner>
</Context>

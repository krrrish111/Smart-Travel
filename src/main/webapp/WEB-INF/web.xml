<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <listener>
        <listener-class>com.voyastra.util.ActiveSessionListener</listener-class>
    </listener>

    <filter>
        <filter-name>GlobalExceptionFilter</filter-name>
        <filter-class>com.voyastra.filter.GlobalExceptionFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>GlobalExceptionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Security Filter -->
    <filter>
        <filter-name>SecurityFilter</filter-name>
        <filter-class>com.voyastra.filter.SecurityFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Global Session Configuration -->
    <session-config>
        <session-timeout>30</session-timeout> <!-- Minutes -->
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure> <!-- Set to true if deploying with HTTPS -->
            <max-age>1800</max-age> <!-- 30 mins -->
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- Global Error Pages mapped to our custom error.jsp -->
    <error-page>
        <error-code>404</error-code>
        <location>/pages/error.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/pages/error.jsp</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/pages/error.jsp</location>
    </error-page>

    <!-- Professional URL Mappings for JSPs -->
    <servlet>
        <servlet-name>AdminDashboard</servlet-name>
        <jsp-file>/admin/index.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboard</servlet-name>
        <url-pattern>/admin</url-pattern>
        <url-pattern>/admin/</url-pattern>
        <url-pattern>/admin/index</url-pattern>
        <url-pattern>/admin-dashboard.jsp</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminUsers</servlet-name>
        <jsp-file>/admin/users.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUsers</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminBookings</servlet-name>
        <jsp-file>/admin/bookings.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminBookings</servlet-name>
        <url-pattern>/admin/bookings</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminPlans</servlet-name>
        <jsp-file>/admin/plans.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminPlans</servlet-name>
        <url-pattern>/admin/plans</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminDestinations</servlet-name>
        <jsp-file>/admin/destinations.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDestinations</servlet-name>
        <url-pattern>/admin/destinations</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminReviews</servlet-name>
        <jsp-file>/admin/reviews.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminReviews</servlet-name>
        <url-pattern>/admin/reviews</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminCommunity</servlet-name>
        <jsp-file>/admin/community.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminCommunity</servlet-name>
        <url-pattern>/admin/community</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminContent</servlet-name>
        <jsp-file>/admin/content.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminContent</servlet-name>
        <url-pattern>/admin/content</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminActivities</servlet-name>
        <jsp-file>/admin/activities.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminActivities</servlet-name>
        <url-pattern>/admin/activities</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminLogs</servlet-name>
        <jsp-file>/admin/logs.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminLogs</servlet-name>
        <url-pattern>/admin/logs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminPayments</servlet-name>
        <jsp-file>/admin/payments.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminPayments</servlet-name>
        <url-pattern>/admin/payments</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminSettings</servlet-name>
        <jsp-file>/admin/settings.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminSettings</servlet-name>
        <url-pattern>/admin/settings</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.voyastra.controller.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/user-home</url-pattern>
        <url-pattern>/dashboard</url-pattern>
        <url-pattern>/dashboard.jsp</url-pattern>
    </servlet-mapping>



    <servlet>
        <servlet-name>AdminProfile</servlet-name>
        <jsp-file>/admin/profile.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminProfile</servlet-name>
        <url-pattern>/admin/profile</url-pattern>
    </servlet-mapping>



    <servlet>
        <servlet-name>Settings</servlet-name>
        <jsp-file>/pages/profile/settings.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>Settings</servlet-name>
        <url-pattern>/settings</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>BookingPage</servlet-name>
        <jsp-file>/pages/booking/booking.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingPage</servlet-name>
        <url-pattern>/booking</url-pattern>
    </servlet-mapping>






    <!-- Community Creator Hub -->
    <servlet>
        <servlet-name>CreatorHub</servlet-name>
        <jsp-file>/pages/community/creator-hub.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>CreatorHub</servlet-name>
        <url-pattern>/community/creator-hub</url-pattern>
    </servlet-mapping>

    <!-- Community Reels -->
    <servlet>
        <servlet-name>ReelsServlet</servlet-name>
        <servlet-class>com.voyastra.controller.community.ReelsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReelsServlet</servlet-name>
        <url-pattern>/community/reels</url-pattern>
    </servlet-mapping>

    <!-- Community Hidden Gems -->
    <servlet>
        <servlet-name>HiddenGemsServlet</servlet-name>
        <servlet-class>com.voyastra.controller.community.HiddenGemsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HiddenGemsServlet</servlet-name>
        <url-pattern>/community/hidden-gems</url-pattern>
    </servlet-mapping>

    <!-- Community Food Discovery -->
    <servlet>
        <servlet-name>FoodServlet</servlet-name>
        <servlet-class>com.voyastra.controller.community.FoodServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FoodServlet</servlet-name>
        <url-pattern>/community/food</url-pattern>
    </servlet-mapping>

    <!-- Community Guide Marketplace -->
    <servlet>
        <servlet-name>GuidesServlet</servlet-name>
        <servlet-class>com.voyastra.controller.community.GuidesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GuidesServlet</servlet-name>
        <url-pattern>/community/guides</url-pattern>
    </servlet-mapping>

    <!-- Community Challenges -->
    <servlet>
        <servlet-name>ChallengesServlet</servlet-name>
        <servlet-class>com.voyastra.controller.community.ChallengesServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChallengesServlet</servlet-name>
        <url-pattern>/community/challenges</url-pattern>
    </servlet-mapping>

    <!-- Community AI Discover Engine -->
    <servlet>
        <servlet-name>DiscoverServlet</servlet-name>
        <servlet-class>com.voyastra.controller.community.DiscoverServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DiscoverServlet</servlet-name>
        <url-pattern>/community/discover</url-pattern>
    </servlet-mapping>

    <!-- Community User Profiles: /community/user/{username} -->
    <servlet>
        <servlet-name>UserProfile</servlet-name>
        <servlet-class>com.voyastra.controller.community.UserProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserProfile</servlet-name>
        <url-pattern>/community/user/*</url-pattern>
    </servlet-mapping>

    <!-- Welcome File List: Routes root to HomeServlet -->
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

</web-app>
